---
import { Card } from './Card';
import { CardAtra } from './Card-atra';
import { CardNft } from './Card-nft';
---

<section
    id="work"
    class="flex h-full w-full flex-col items-center justify-center gap-20 pt-8 md:mb-40 md:gap-40"
>
    <div class="mb-[-2rem] w-full px-10 md:mb-[-7rem] md:w-[65vw]">
        <h2 class="section-title text-[2.5rem]">Work</h2>
        <p class="section-title text-[1rem] md:text-[1.5rem]">
            Check it out some of my side projects.
        </p>
    </div>
    <Card
        title="Atra Architecture"
        date="2023 10 05"
        description="Professional architecture portfolio with CMS"
        mainImage="../assets/images/atra-bg.png"
        githubUrl="https://github.com/oscarprdev/Atra-architecture-web"
        appUrl="https://atra-architecture.vercel.app/"
        client:load
    >
        <CardAtra client:load />
    </Card>
    <Card
        title="NFT Market"
        date="2023 9 17"
        description="NFT marketplace UI design with View Transitions API"
        mainImage="../assets/images/nft-bg.png"
        githubUrl="https://github.com/oscarprdev/Nft-market-transitions"
        appUrl="https://nft-market-transitions.netlify.app/"
        client:load
    >
        <CardNft client:load />
    </Card>
</section>
