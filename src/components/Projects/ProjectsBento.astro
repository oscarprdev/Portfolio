---
import Golang from '../../icons/Golang.astro';
import Next from '../../icons/Next.astro';
import React from '../../icons/React.astro';
import Ts from '../../icons/Ts.astro';
import Vue from '../../icons/Vue.astro';
import ProjectCard from './ProjectCard.astro';

import { getI18N } from '../../i18n';

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
---

<section class="projects__bento">
    <ProjectCard
        order={1}
        src="/assets/atra.png"
        title={i18n.PROJECTS.PROJECT_1.TITLE}
        description={i18n.PROJECTS.PROJECT_1.DESCRIPTION}
        projectLink="https://atra-architectura.vercel.app/"
        codeLink="https://github.com/oscarprdev/Atra-architecture"
    >
        <div
            class="stack"
            slot="stack"
        >
            <Ts />
            <Vue />
        </div>
    </ProjectCard>
    <ProjectCard
        order={2}
        src="/assets/twitter.png"
        title={i18n.PROJECTS.PROJECT_2.TITLE}
        description={i18n.PROJECTS.PROJECT_2.DESCRIPTION}
        projectLink="https://opr-twitter-clone.vercel.app/"
        codeLink="https://github.com/oscarprdev/Twitter_clone"
    >
        <div
            class="stack"
            slot="stack"
        >
            <Ts />
            <React />
            <Golang />
        </div>
    </ProjectCard>
    <ProjectCard
        order={3}
        src="/assets/url.png"
        title={i18n.PROJECTS.PROJECT_3.TITLE}
        description={i18n.PROJECTS.PROJECT_3.DESCRIPTION}
        projectLink="https://opr-short-url.vercel.app/"
        codeLink="https://github.com/oscarprdev/Short_url"
    >
        <div
            class="stack"
            slot="stack"
        >
            <Ts />
            <React />
            <Golang />
        </div>
    </ProjectCard>
    <ProjectCard
        order={4}
        src="/assets/ai.png"
        title={i18n.PROJECTS.PROJECT_4.TITLE}
        description={i18n.PROJECTS.PROJECT_4.DESCRIPTION}
        projectLink="https://nft-ai-generator-two.vercel.app/"
        codeLink="https://github.com/oscarprdev/nft-ai-generator/tree/main/frontend"
    >
        <div
            class="stack"
            slot="stack"
        >
            <Ts />
            <Next />
        </div>
    </ProjectCard>
</section>

<style>
    .projects__bento {
        width: 100%;
        height: 80%;
        display: grid;
        gap: 0.5rem;
        grid-template-areas:
            'a a b'
            'c d d';
    }

    .stack {
        display: flex;
        align-items: center;
        gap: 0.4rem;

        .shared-icon {
            width: 1.1rem;
            height: 1.1rem;
            color: var(--default-color-light);
        }
    }

    :global(.project-1) {
        grid-area: a;
    }

    :global(.project-2) {
        grid-area: b;
    }

    :global(.project-3) {
        grid-area: c;
    }

    :global(.project-4) {
        grid-area: d;
    }

    @media (width <= 800px) {
        .projects__bento {
            display: flex;
            flex-direction: column;
            height: fit-content;
            padding-bottom: 5rem;
        }
    }
</style>
