---
import ArrowUpRight from '../../icons/ArrowUpRight.astro';
import ArrowAnimated from '../common/ArrowAnimated.astro';

interface Props {
    link: string;
    text: string;
    kind: string;
}

const { link, text, kind } = Astro.props;
---

<a
    class={`link ${kind}-link`}
    href={link}
    target="_blank"
    ><p class="link-text">{text}</p>
    <ArrowAnimated up><ArrowUpRight /></ArrowAnimated></a
>

<style>
    .link {
        position: relative;
        display: flex;
        align-items: center;
        padding: 0.5rem 1rem;
        gap: 0.5rem;
        border-radius: 1rem;

        box-shadow: var(--box-shadow);
        box-sizing: border-box;
    }

    .code-link {
        border: 1px solid rgb(172, 172, 172);
        border-radius: var(--border-radius);
        padding: 0.9rem 1.8rem;
    }

    .project-link {
        background: linear-gradient(
            to right,
            var(--badge-container-dark),
            var(--badge-container-light)
        );

        border-radius: var(--border-radius);
        padding: 0.9rem 1.8rem;
        border: 1px solid rgb(172, 172, 172);
    }

    .link .link-text {
        line-height: 0%;
        padding: 0;
        margin: 0;
    }

    .link .link-text::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0.6rem;
        height: 1px;
        left: 1.8rem;
        width: 35%;
        background-color: white;
        transform: scaleX(0);
        transition: transform 0.3s ease;
        transform-origin: left;
    }

    .link:hover p::after {
        transform: scaleX(1);
    }

    .link:hover :global(.icon-container .icon),
    .link:hover :global(.icon-container .icon-2) {
        transform: translateY(-55%) translateX(50%);
    }
</style>
