---
import HeroAboutTitle from './HeroAboutTitle.astro';
import WorkingBadge from './WorkingBadge.astro';
---

<article class="hero_about">
    <picture class="hero_about__image">
        <img
            src="/assets/me.webp"
            alt="Personal image"
        />
    </picture>
    <section class="hero_about__content">
        <HeroAboutTitle />
        <WorkingBadge />
    </section>
</article>

<style>
    .hero_about {
        width: fit-content;
        height: 45vh;
        display: flex;
        align-items: start;
        gap: 2rem;
    }

    .hero_about__image {
        position: relative;

        display: grid;
        place-items: center;
        border-radius: 50%;
        width: 300px;
        max-width: 30vw;
        box-shadow: var(--box-shadow);

        img {
            aspect-ratio: 400/420;
            border-radius: 50%;
        }
    }

    .hero_about__content {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 1rem;
        height: 100%;
    }

    @media (width <= 800px) {
        .hero_about {
            height: 25vh;

            gap: 1rem;
        }

        .hero_about__image {
            width: 200px;
        }
    }

    @media (width <= 550px) {
        .hero_about {
            height: 50vh;
            width: 100%;
            align-items: center;
            flex-direction: column;
        }

        .hero_about__image {
            width: auto;
        }

        .hero_about__content {
            height: 25vh;
            align-items: end;
            margin-top: -1rem;
        }
    }
</style>
