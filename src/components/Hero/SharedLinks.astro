---
import Cv from '../../icons/Cv.astro';
import Linkedin from '../../icons/Linkedin.astro';
import Github from '../../icons/Github.astro';
import SharedIconBox from './SharedIconBox.astro';
import { getI18N } from '../../i18n';

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
---

<div class="shared-links">
    <SharedIconBox
        href=""
        tooltip={i18n.HERO.DOWNLOAD_CV_MESSAGE}
    >
        <Cv />
    </SharedIconBox>
    <SharedIconBox href="https://www.linkedin.com/in/oscarperez8/">
        <Linkedin />
    </SharedIconBox>
    <SharedIconBox href="https://github.com/oscarprdev">
        <Github />
    </SharedIconBox>
</div>

<style>
    .shared-links {
        display: flex;
        flex-direction: column;
        justify-content: end;
        align-items: center;
        margin-top: 7rem;
        gap: 1rem;
    }

    @media (width <= 800px) {
        .shared-links {
            flex-direction: row;
            margin-top: 0;
            align-self: end;
        }
    }
</style>
