---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="Oscar Portfolio"
        />
        <meta
            name="viewport"
            content="width=device-width"
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon.svg"
        />
        <meta
            name="generator"
            content={Astro.generator}
        />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>
<style is:global>
    :root {
        /* Fonts Sizes*/
        --title-size: 5rem;

        /* Colors */
        --red-light: #ff1e0b;

        /* --default-color: #333; */
        --default-color: #dedede;
        --default-color-light: #b5b5b5;

        --badge-dark: #2d3299;
        --badge-light: #773e9d;

        --badge-container-dark: #6982ff;
        --badge-container-light: #dca7ff;

        --bg-glow: #6982ff1a;
        /* Backgrounds */
        /* --bg-screen: #ededed; */
        --bg-screen: #13151a;

        /* Shadow */
        --box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
    }

    @font-face {
        font-family: 'HelveticaNeue';
        src: url('/fonts/HelveticaNeue.otf') format('opentype');
        font-display: swap;
    }

    html {
        background: #13151a;
        background-size: 224px;
        scroll-behavior: smooth;
    }

    * {
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif, system-ui;

        color: var(--default-color);
        background-color: var(--bg-screen);

        margin: 0;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    h1 {
        font-family: Arial, Helvetica, sans-serif, system-ui;
    }

    ul {
        list-style: none;
    }

    li {
        text-indent: 0;
        list-style-type: 0;
    }

    h2 {
        font-family: system-ui;
    }

    picture {
        overflow: hidden;
    }

    img {
        object-fit: cover;
        height: 100%;
        width: 100%;
    }

    .shared-icon {
        display: grid;
        place-items: center;
        z-index: 10;
    }

    .bg-noise {
        background-position: 50%;
        background-repeat: repeat;
        background-image: url(/assets/noise.png);
        background-size: 140px 100px;
    }

    .section-title {
        background: radial-gradient(50% 75% at 10% 10%, #f1f1f192 0, #ffffff);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .color-text {
        background: linear-gradient(
            to right,
            var(--badge-container-dark) 15%,
            var(--badge-container-light) 45%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .show {
        view-timeline-name: --show;
        view-timeline-axis: block;

        animation-timeline: --show;
        animation-name: show;
        animation-range: entry 18% cover 50%;
        animation-fill-mode: both;
    }

    @keyframes show {
        from {
            opacity: 0;
            transform: translateY(55%);
        }

        to {
            opacity: 1;
            transform: translateY(0%);
        }
    }
</style>
